{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/esj1123/codex-dev-harness/audits/receipt-summary.schema.json",
  "title": "codex-dev-harness receipt summary",
  "description": "Core JSON evidence schema for safe task receipt summaries. This schema defines shape only and does not enable audit automation or real audit logs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evidence_kind",
    "receipt_id",
    "task_id",
    "repository",
    "basis",
    "approval",
    "side_effect_class",
    "changed_files",
    "commands",
    "verification",
    "safety",
    "artifacts",
    "status_label",
    "unresolved_risks",
    "next_step"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "1.0"
      ]
    },
    "evidence_kind": {
      "type": "string",
      "const": "receipt_summary"
    },
    "receipt_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "description": "Stable identifier for one receipt summary. Do not include raw prompts, private data, raw command logs, tool-call bodies, local absolute paths, secrets, account values, IPs, ports, live config, or device values."
    },
    "task_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "description": "Stable task or phase identifier. Do not include raw prompts."
    },
    "repository": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Repository identifier such as owner/name or a safe local label."
    },
    "basis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "branch",
        "head_commit",
        "origin_commit",
        "local_remote_relationship"
      ],
      "properties": {
        "branch": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "head_commit": {
          "$ref": "#/$defs/commit_or_unknown"
        },
        "origin_commit": {
          "$ref": "#/$defs/commit_or_unknown"
        },
        "local_remote_relationship": {
          "type": "string",
          "enum": [
            "equal",
            "ahead",
            "behind",
            "diverged",
            "unknown",
            "not checked"
          ]
        },
        "branch_ahead_count": {
          "type": "integer",
          "minimum": 0
        },
        "branch_behind_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approval_class",
        "approval_reference"
      ],
      "properties": {
        "approval_class": {
          "type": "string",
          "enum": [
            "read_only",
            "documentation_only",
            "owner_approved_local_edit",
            "owner_approved_local_commit",
            "owner_approved_push",
            "owner_approved_workflow_dispatch",
            "release_publication_approved",
            "not_applicable"
          ]
        },
        "approval_reference": {
          "$ref": "#/$defs/safe_summary"
        }
      }
    },
    "side_effect_class": {
      "type": "string",
      "enum": [
        "read_only_inspection",
        "documentation_edit",
        "schema_edit",
        "test_edit",
        "quality_gate_validation",
        "local_git_commit",
        "remote_push",
        "manual_workflow_dispatch",
        "artifact_generation",
        "release_publication",
        "downstream_edit",
        "live_target_action"
      ]
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "change_type"
        ],
        "properties": {
          "path": {
            "$ref": "#/$defs/repo_relative_path"
          },
          "change_type": {
            "type": "string",
            "enum": [
              "added",
              "modified",
              "deleted",
              "renamed"
            ]
          },
          "content_hash": {
            "$ref": "#/$defs/hash_record"
          }
        }
      }
    },
    "commands": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run",
        "not_run"
      ],
      "properties": {
        "run": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/command_result"
          }
        },
        "not_run": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/not_run_result"
          }
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result",
        "summary"
      ],
      "properties": {
        "result": {
          "$ref": "#/$defs/status_label"
        },
        "summary": {
          "$ref": "#/$defs/safe_summary"
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "redaction_status",
        "exclusions"
      ],
      "properties": {
        "redaction_status": {
          "$ref": "#/$defs/redaction_status"
        },
        "exclusions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/safe_summary"
          }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "generated",
        "release_artifact_status",
        "artifact_upload_status"
      ],
      "properties": {
        "generated": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/repo_relative_path"
          }
        },
        "release_artifact_status": {
          "type": "string",
          "enum": [
            "not generated",
            "generated by separate approval",
            "not applicable",
            "not checked"
          ]
        },
        "artifact_upload_status": {
          "type": "string",
          "enum": [
            "none",
            "uploaded",
            "not applicable",
            "not checked"
          ]
        }
      }
    },
    "eval_evidence": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional Phase 5B eval evidence reference. Use only for standalone eval evidence that was explicitly run or cited. Summary JSON is safe summary evidence; cases JSONL is detailed evidence referenced by cases_ref and cases_sha256. Do not copy full case details into receipts.",
      "required": [
        "eval_command",
        "eval_scope",
        "eval_report_generation_status",
        "eval_integration_status",
        "eval_gate_status",
        "release_blocking_status"
      ],
      "properties": {
        "eval_command": {
          "$ref": "#/$defs/safe_summary"
        },
        "eval_scope": {
          "$ref": "#/$defs/safe_summary"
        },
        "eval_case_count": {
          "type": "integer",
          "minimum": 0
        },
        "eval_pass_count": {
          "type": "integer",
          "minimum": 0
        },
        "eval_fail_count": {
          "type": "integer",
          "minimum": 0
        },
        "summary_report_path": {
          "$ref": "#/$defs/repo_relative_path",
          "description": "Repo-relative path to the explicitly generated eval summary JSON, when cited."
        },
        "summary_report_sha256": {
          "$ref": "#/$defs/sha256_value",
          "description": "SHA-256 of the eval summary JSON bytes, when cited."
        },
        "cases_ref": {
          "$ref": "#/$defs/repo_relative_path",
          "description": "Repo-relative cases JSONL reference. When sourced from a split summary report, this should match that report's cases_ref."
        },
        "cases_sha256": {
          "$ref": "#/$defs/sha256_value",
          "description": "SHA-256 of the cases JSONL bytes. When sourced from a split summary report, this should match that report's cases_sha256."
        },
        "eval_report_generation_status": {
          "type": "string",
          "enum": [
            "not generated",
            "generated",
            "not run",
            "blocked"
          ]
        },
        "eval_integration_status": {
          "type": "string",
          "enum": [
            "standalone",
            "receipt-summary-only",
            "ci-approved",
            "not applicable",
            "not checked"
          ]
        },
        "eval_gate_status": {
          "type": "string",
          "enum": [
            "not integrated",
            "not applicable",
            "not checked"
          ]
        },
        "release_blocking_status": {
          "type": "string",
          "enum": [
            "not release-blocking",
            "not applicable",
            "not checked"
          ]
        },
        "notes_or_failures_summary": {
          "$ref": "#/$defs/safe_summary"
        }
      }
    },
    "retrieval_evidence": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional Phase 7D retrieval evidence reference. Use only for explicitly reviewed standalone retrieval evidence or an explicit not-run record. Store safe summaries, repo-relative paths, hashes, counts, and commit identifiers only; do not copy raw retriever stdout, full documents, raw prompts, private data, command logs, tool-call bodies, secrets, live values, or local absolute paths.",
      "required": [
        "retrieval_status",
        "retrieval_mode",
        "source_count",
        "citations",
        "output_capture",
        "retrieval_integration_status"
      ],
      "properties": {
        "retrieval_status": {
          "$ref": "#/$defs/retrieval_status"
        },
        "retrieval_mode": {
          "type": "string",
          "enum": [
            "not_run",
            "standalone_manual",
            "standalone_cli_output_reference",
            "not_applicable"
          ]
        },
        "query_summary": {
          "$ref": "#/$defs/safe_summary",
          "description": "Short sanitized query summary only. Do not store prompt transcripts."
        },
        "query_class": {
          "$ref": "#/$defs/retrieval_query_class"
        },
        "source_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "citations": {
          "type": "array",
          "maxItems": 10,
          "items": {
            "$ref": "#/$defs/retrieval_citation"
          }
        },
        "no_answer_reason": {
          "$ref": "#/$defs/safe_summary"
        },
        "safety_notes": {
          "type": "array",
          "maxItems": 20,
          "items": {
            "$ref": "#/$defs/safe_summary"
          }
        },
        "digest_ref": {
          "$ref": "#/$defs/repo_relative_path",
          "description": "Repo-relative digest path when stable digest evidence is cited."
        },
        "digest_source_basis_commit": {
          "$ref": "#/$defs/commit_or_unknown"
        },
        "observed_head_commit": {
          "$ref": "#/$defs/commit_or_unknown",
          "description": "Committed HEAD used for volatile authority evidence, when cited."
        },
        "output_capture": {
          "type": "string",
          "enum": [
            "none",
            "redacted_summary_only",
            "bounded_citations_only"
          ]
        },
        "retrieval_integration_status": {
          "type": "string",
          "enum": [
            "receipt-summary-only",
            "trace-reference-only",
            "not integrated",
            "not applicable",
            "not checked"
          ]
        }
      }
    },
    "hermes_git_push_preflight_evidence": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional Phase 9Q Hermes git-push preflight evidence reference. Use only for explicitly reviewed safe selected fields or an explicit not-run record. Store bounded summaries, booleans, repo-relative evidence references, commit identifiers, and Local Verify run/job identifiers only; do not copy raw preflight stdout, raw prompts, private data, command logs, tool-call bodies, secrets, live values, local absolute paths, or approval conversation text.",
      "required": [
        "preflight_evidence_status",
        "preflight_output_mode",
        "caller_schema_version",
        "caller_mode",
        "decision",
        "side_effect_requested",
        "guarded_command",
        "would_run_git_push",
        "performed_actions_empty",
        "reason_code",
        "stop_reasons",
        "approval_ref_present",
        "evidence_refs",
        "output_capture",
        "preflight_integration_status"
      ],
      "properties": {
        "preflight_evidence_status": {
          "type": "string",
          "enum": [
            "stopped",
            "blocked",
            "not_run",
            "not_applicable"
          ]
        },
        "preflight_output_mode": {
          "type": "string",
          "enum": [
            "stdout_only",
            "manual_summary",
            "selected_fields",
            "none"
          ]
        },
        "caller_schema_version": {
          "$ref": "#/$defs/safe_summary",
          "description": "Expected current value is hermes_git_push_preflight.v0. Store a short schema identifier only."
        },
        "caller_mode": {
          "type": "string",
          "enum": [
            "dry_run",
            "not checked",
            "not applicable"
          ]
        },
        "decision": {
          "type": "string",
          "enum": [
            "STOP",
            "not checked",
            "not applicable"
          ]
        },
        "side_effect_requested": {
          "type": "string",
          "enum": [
            "git_push",
            "none",
            "not checked",
            "not applicable"
          ]
        },
        "guarded_command": {
          "type": "string",
          "enum": [
            "git push",
            "not checked",
            "not applicable"
          ],
          "description": "Safe command label only; do not store a raw command log."
        },
        "would_run_git_push": {
          "type": "boolean"
        },
        "performed_actions_empty": {
          "type": "boolean"
        },
        "reason_code": {
          "$ref": "#/$defs/safe_summary"
        },
        "stop_reasons": {
          "type": "array",
          "maxItems": 20,
          "items": {
            "$ref": "#/$defs/safe_summary"
          }
        },
        "approval_ref_present": {
          "type": "boolean",
          "description": "Boolean only; do not store approval conversation text."
        },
        "evidence_refs": {
          "type": "array",
          "maxItems": 20,
          "items": {
            "$ref": "#/$defs/repo_relative_path"
          }
        },
        "hermes_result_summary": {
          "$ref": "#/$defs/safe_summary",
          "description": "Selected safe nested Hermes fields only; do not store full raw sidecar output."
        },
        "safe_task_summary": {
          "$ref": "#/$defs/safe_summary",
          "description": "Sanitized task summary only; do not store prompt transcripts."
        },
        "safety_notes": {
          "type": "array",
          "maxItems": 20,
          "items": {
            "$ref": "#/$defs/safe_summary"
          }
        },
        "observed_head_commit": {
          "$ref": "#/$defs/commit_or_unknown"
        },
        "local_verify_run_id": {
          "$ref": "#/$defs/safe_summary",
          "description": "Safe reviewed workflow run identifier when relevant."
        },
        "local_verify_job_id": {
          "$ref": "#/$defs/safe_summary",
          "description": "Safe reviewed workflow job identifier when relevant."
        },
        "output_capture": {
          "type": "string",
          "enum": [
            "none",
            "redacted_summary",
            "selected_fields"
          ]
        },
        "preflight_integration_status": {
          "type": "string",
          "enum": [
            "receipt-summary-only",
            "trace-reference-only",
            "not integrated",
            "not applicable",
            "not checked"
          ]
        }
      }
    },
    "status_label": {
      "$ref": "#/$defs/status_label"
    },
    "unresolved_risks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/safe_summary"
      }
    },
    "next_step": {
      "$ref": "#/$defs/safe_summary"
    }
  },
  "$defs": {
    "status_label": {
      "type": "string",
      "enum": [
        "PASS",
        "PASS WITH NOTES",
        "BLOCKED",
        "NOT RUN",
        "ENVIRONMENT BLOCKED",
        "FAIL"
      ]
    },
    "safe_summary": {
      "type": "string",
      "minLength": 0,
      "maxLength": 2000,
      "description": "Redacted summary only. Do not store raw prompts, private data, raw command logs, unredacted tool-call bodies, secrets, live values, local absolute paths, or generated downstream source."
    },
    "repo_relative_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 260,
      "pattern": "^(?![A-Za-z]:)(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/() -]+$",
      "description": "Repository-relative path only."
    },
    "commit_or_unknown": {
      "type": "string",
      "pattern": "^([0-9a-fA-F]{7,40}|unknown|not checked|not applicable)$"
    },
    "sha256_value": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{64}$"
    },
    "retrieval_status": {
      "type": "string",
      "enum": [
        "not_run",
        "found",
        "partial",
        "no_sufficient_evidence",
        "blocked",
        "not_applicable"
      ]
    },
    "retrieval_query_class": {
      "type": "string",
      "enum": [
        "durable_policy",
        "current_state",
        "historical_decision",
        "mixed_context",
        "unknown",
        "not_applicable"
      ]
    },
    "retrieval_citation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_path",
        "hash",
        "hash_kind",
        "citation_scope",
        "summary"
      ],
      "properties": {
        "source_path": {
          "$ref": "#/$defs/repo_relative_path"
        },
        "hash": {
          "$ref": "#/$defs/sha256_value"
        },
        "hash_kind": {
          "type": "string",
          "enum": [
            "digest_content_hash",
            "volatile_content_hash"
          ]
        },
        "citation_scope": {
          "type": "string",
          "enum": [
            "stable_digest",
            "volatile_committed_head"
          ]
        },
        "summary": {
          "$ref": "#/$defs/safe_summary"
        },
        "authority_note": {
          "$ref": "#/$defs/safe_summary"
        }
      }
    },
    "hash_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "value"
      ],
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": [
            "sha256"
          ]
        },
        "value": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{64}$"
        }
      }
    },
    "command_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command_summary",
        "result",
        "note"
      ],
      "properties": {
        "command_summary": {
          "$ref": "#/$defs/safe_summary"
        },
        "result": {
          "$ref": "#/$defs/status_label"
        },
        "note": {
          "$ref": "#/$defs/safe_summary"
        }
      }
    },
    "not_run_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command_summary",
        "result",
        "reason"
      ],
      "properties": {
        "command_summary": {
          "$ref": "#/$defs/safe_summary"
        },
        "result": {
          "type": "string",
          "enum": [
            "NOT RUN",
            "ENVIRONMENT BLOCKED"
          ]
        },
        "reason": {
          "$ref": "#/$defs/safe_summary"
        }
      }
    },
    "redaction_status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "notes"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "not_needed",
            "redacted",
            "approved_summary_only",
            "blocked_sensitive_content"
          ]
        },
        "notes": {
          "$ref": "#/$defs/safe_summary"
        }
      }
    }
  }
}
