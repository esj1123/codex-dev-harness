# Optional local verification workflow template.
# This file is not active unless a user manually copies it to .github/workflows/.
# The codex-dev-harness baseline is local-first and does not require GitHub Actions.

name: Local Verify

on:
  workflow_dispatch:
  pull_request:
    paths:
      - "**.md"
      - "docs/**"
      - "scripts/**"
      - "tests/**"
      - "templates/**"
      - "profiles/**"
      - "examples/**"
      - "requirements-dev.txt"
      - "template.config.example.yml"

permissions:
  contents: read

jobs:
  local-verify:
    runs-on: windows-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Install development requirements
        run: python -m pip install -r requirements-dev.txt

      - name: Run tests
        run: python -m pytest

      - name: Run quality gate
        run: python scripts/quality_gate.py

      - name: Render python_cli example dry-run
        run: python scripts/render_template.py --config examples/python_cli_minimal/template.config.yml --target examples/python_cli_minimal --dry-run

      - name: Render csharp_desktop example dry-run
        run: python scripts/render_template.py --config examples/csharp_desktop_minimal/template.config.yml --target examples/csharp_desktop_minimal --dry-run

      - name: Render plc_tool example dry-run
        run: python scripts/render_template.py --config examples/plc_tool_minimal/template.config.yml --target examples/plc_tool_minimal --dry-run
